SECRET_KEY=your-django-secret-key-here
DEBUG=True
# PostgreSQL (uncomment and fill in when ready):
# DATABASE_URL=postgres://postgres:postgres@localhost:5432/clover_notify
# For dev with zero setup, Django falls back to SQLite below:
DATABASE_URL=sqlite:///db.sqlite3

# Clover webhook verification token (leave blank to skip verification in dev)
CLOVER_WEBHOOK_SECRET=

# Twilio credentials (fill in to enable real SMS sending)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Merchant info (used in SMS template)
MERCHANT_NAME=Your Shop Name
